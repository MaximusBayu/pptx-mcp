# --- web ---
DATABASE_URL=postgresql://pptx:pptx@postgres:5432/pptx
AUTH_SECRET=change-me-long-random
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ENGINE_URL=http://engine-service:8000
# --- s3 (minio) ---
S3_ENDPOINT=http://minio:9000
# Host/browser-reachable endpoint used to SIGN download URLs. Internal
# S3_ENDPOINT (minio:9000) only resolves inside the compose network, so a
# host browser can't open those links. Set this to a host-reachable address
# (localhost for dev, or a public S3/R2 endpoint in prod). Leave unset to
# fall back to S3_ENDPOINT (fine when only in-network agents download).
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pptx
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# --- mcp-server ---
WEB_URL=http://web:3000
PPTX_API_KEY=
